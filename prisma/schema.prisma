generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// 分析済み記事（メインページ）
model Article {
  id             String                 @id(map: "Article_pkey") @default(cuid())
  title          String
  content        String
  url            String?
  source         String?
  publishedAt    String?                @map("published_at")
  analyzedAt     DateTime               @default(now()) @map("analyzed_at")
  economic       Float
  social         Float
  diplomatic     Float
  emotionalTone  Float                  @map("emotional_tone")
  biasWarning    Boolean                @map("bias_warning")
  confidence     Float
  summary        String
  counterOpinion String                 @map("counter_opinion")
  category       String?
  subcategory    String?
  embedding      Unsupported("vector")?

  @@index([analyzedAt(sort: Desc)], map: "Article_analyzedAt_idx")
  @@index([url], map: "Article_url_idx")
  @@map("articles")
}

/// RSSフィードから取得した生記事（永続化・重複排除用）
model RssArticle {
  id           String                 @id(map: "RssArticle_pkey") @default(cuid())
  url          String                 @unique(map: "RssArticle_url_key")
  title        String
  source       String
  summary      String?
  imageUrl     String?                @map("image_url")
  publishedAt  DateTime?              @map("published_at")
  category     String?
  subcategory  String?
  fetchedAt    DateTime               @default(now()) @map("fetched_at")
  embeddedAt   DateTime?              @map("embedded_at") @db.Timestamptz(6)
  classifiedAt DateTime?              @map("classified_at") @db.Timestamptz(6)
  embedding    Unsupported("vector")?

  @@index([fetchedAt(sort: Desc)], map: "RssArticle_fetchedAt_idx")
  @@index([publishedAt(sort: Desc)], map: "RssArticle_publishedAt_idx")
  @@map("rss_articles")
}

/// RSSフィードのニュースイベントグループ（インクリメンタルグループ化用）
model FeedGroup {
  id           String                 @id(map: "FeedGroup_pkey") @default(cuid())
  title        String
  articleCount Int                    @default(0) @map("article_count")
  lastSeenAt   DateTime               @default(now()) @map("last_seen_at")
  createdAt    DateTime               @default(now()) @map("created_at")
  embedding    Unsupported("vector")?
  items        FeedGroupItem[]

  @@index([lastSeenAt(sort: Desc)], map: "FeedGroup_lastSeenAt_idx")
  @@map("feed_groups")
}

/// FeedGroup に属する記事（重複防止・centroid更新用）
model FeedGroupItem {
  id          String    @id(map: "FeedGroupItem_pkey") @default(cuid())
  groupId     String    @map("group_id")
  title       String
  url         String
  source      String
  publishedAt String?   @map("published_at")
  matchedAt   DateTime  @default(now()) @map("matched_at")
  group       FeedGroup @relation(fields: [groupId], references: [id], onDelete: Cascade, map: "FeedGroupItem_groupId_fkey")

  @@unique([groupId, url], map: "FeedGroupItem_groupId_url_key")
  @@index([url], map: "FeedGroupItem_url_idx")
  @@map("feed_group_items")
}

/// Goバッチパイプラインの実行結果スナップショット
model ProcessedSnapshot {
  id           String          @id(map: "ProcessedSnapshot_pkey") @default(dbgenerated("(gen_random_uuid())::text"))
  processedAt  DateTime        @default(now()) @map("processed_at") @db.Timestamptz(6)
  articleCount Int             @map("article_count")
  groupCount   Int             @map("group_count")
  durationMs   Int             @map("duration_ms")
  status       String
  error        String?
  groups       SnapshotGroup[]

  @@index([processedAt(sort: Desc)], map: "idx_snapshot_processed")
  @@map("processed_snapshots")
}

/// スナップショット内のニュースグループ
model SnapshotGroup {
  id           String              @id(map: "SnapshotGroup_pkey") @default(dbgenerated("(gen_random_uuid())::text"))
  snapshotId   String              @map("snapshot_id")
  groupTitle   String              @map("group_title")
  category     String?
  subcategory  String?
  rank         Int
  singleOutlet Boolean             @map("single_outlet")
  coveredBy    Json?               @map("covered_by")
  silentMedia  Json?               @map("silent_media")
  items        SnapshotGroupItem[]
  snapshot     ProcessedSnapshot   @relation(fields: [snapshotId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "SnapshotGroup_snapshotId_fkey")

  @@index([snapshotId], map: "idx_sg_snapshot")
  @@map("snapshot_groups")
}

/// グループ内の記事
model SnapshotGroupItem {
  id          String        @id(map: "SnapshotGroupItem_pkey") @default(dbgenerated("(gen_random_uuid())::text"))
  groupId     String        @map("group_id")
  title       String
  url         String
  source      String
  summary     String?
  publishedAt String?       @map("published_at")
  category    String?
  subcategory String?
  group       SnapshotGroup @relation(fields: [groupId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "SnapshotGroupItem_groupId_fkey")

  @@index([groupId], map: "idx_sgi_group")
  @@map("snapshot_group_items")
}

/// メディア比較セッション（比較ページ）
model CompareSession {
  id         String               @id(map: "CompareSession_pkey") @default(cuid())
  keyword    String
  savedAt    DateTime             @default(now()) @map("saved_at")
  groups     Json
  newsGroups CompareGroupRecord[]
  results    CompareResult[]

  @@index([savedAt(sort: Desc)], map: "CompareSession_savedAt_idx")
  @@map("compare_sessions")
}

/// グループ化されたニュースイベント（ベクトル検索用）
model CompareGroupRecord {
  id           String                 @id(map: "CompareGroupRecord_pkey") @default(cuid())
  sessionId    String                 @map("session_id")
  groupTitle   String                 @map("group_title")
  singleOutlet Boolean                @map("single_outlet")
  itemCount    Int                    @map("item_count")
  /// 参加媒体名の配列を JSON で保存
  sources      Json
  savedAt      DateTime               @default(now()) @map("saved_at")
  embedding    Unsupported("vector")?
  session      CompareSession         @relation(fields: [sessionId], references: [id], onDelete: Cascade, map: "CompareGroupRecord_sessionId_fkey")

  @@index([savedAt(sort: Desc)], map: "CompareGroupRecord_savedAt_idx")
  @@map("compare_group_records")
}

/// YouTube 動画の字幕分析結果
model YouTubeVideo {
  id             String                 @id(map: "YouTubeVideo_pkey") @default(cuid())
  videoId        String                 @unique(map: "YouTubeVideo_videoId_key") @map("video_id")
  title          String
  channelName    String                 @map("channel_name")
  channelId      String                 @map("channel_id")
  description    String?
  thumbnailUrl   String?                @map("thumbnail_url")
  publishedAt    String?                @map("published_at")
  transcript     String
  transcriptType String                 @default("transcript") @map("transcript_type")
  analyzedAt     DateTime               @default(now()) @map("analyzed_at")
  economic       Float
  social         Float
  diplomatic     Float
  emotionalTone  Float                  @map("emotional_tone")
  biasWarning    Boolean                @map("bias_warning")
  confidence     Float
  summary        String
  counterOpinion String                 @map("counter_opinion")
  category       String?
  subcategory    String?
  embedding      Unsupported("vector")?

  @@index([analyzedAt(sort: Desc)], map: "YouTubeVideo_analyzedAt_idx")
  @@index([channelId], map: "YouTubeVideo_channelId_idx")
  @@map("youtube_videos")
}

/// 比較セッション内の各媒体分析結果
model CompareResult {
  id             String                 @id(map: "CompareResult_pkey") @default(cuid())
  sessionId      String                 @map("session_id")
  title          String
  url            String?
  source         String?
  publishedAt    String?                @map("published_at")
  analyzedAt     DateTime               @default(now()) @map("analyzed_at")
  economic       Float
  social         Float
  diplomatic     Float
  emotionalTone  Float                  @map("emotional_tone")
  biasWarning    Boolean                @map("bias_warning")
  confidence     Float
  summary        String
  counterOpinion String                 @map("counter_opinion")
  embedding      Unsupported("vector")?
  session        CompareSession         @relation(fields: [sessionId], references: [id], onDelete: Cascade, map: "CompareResult_sessionId_fkey")

  @@map("compare_results")
}
