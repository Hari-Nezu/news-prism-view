generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// 分析済み記事（メインページ）
model Article {
  id             String   @id @default(cuid())
  title          String
  content        String
  url            String?
  source         String?
  publishedAt    String?
  analyzedAt     DateTime @default(now())

  // 3軸スコア
  economic       Float
  social         Float
  diplomatic     Float
  emotionalTone  Float
  biasWarning    Boolean
  confidence     Float
  summary        String
  counterOpinion String

  category       String?
  subcategory    String?

  // 埋め込みベクトル（ruri-v3-310m = 1024次元）
  // Prisma未対応型のため INSERT/SELECT は生SQL で処理
  embedding      Unsupported("vector(1024)")?

  @@index([url])
  @@index([analyzedAt(sort: Desc)])
}

/// RSSフィードから取得した生記事（永続化・重複排除用）
model RssArticle {
  id          String    @id @default(cuid())
  url         String    @unique
  title       String
  source      String
  summary     String?
  imageUrl    String?
  publishedAt DateTime?
  category    String?
  subcategory String?
  fetchedAt   DateTime  @default(now())

  @@index([fetchedAt(sort: Desc)])
  @@index([publishedAt(sort: Desc)])
}

/// RSSフィードのニュースイベントグループ（インクリメンタルグループ化用）
model FeedGroup {
  id           String          @id @default(cuid())
  title        String
  articleCount Int             @default(0)
  lastSeenAt   DateTime        @default(now())
  createdAt    DateTime        @default(now())
  embedding    Unsupported("vector(1024)")?
  items        FeedGroupItem[]

  @@index([lastSeenAt(sort: Desc)])
}

/// FeedGroup に属する記事（重複防止・centroid更新用）
model FeedGroupItem {
  id          String    @id @default(cuid())
  group       FeedGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  groupId     String
  title       String
  url         String
  source      String
  publishedAt String?
  matchedAt   DateTime  @default(now())

  @@unique([groupId, url])
  @@index([url])
}

/// メディア比較セッション（比較ページ）
model CompareSession {
  id      String   @id @default(cuid())
  keyword String
  savedAt DateTime @default(now())

  // NewsGroup[] を JSON で保存
  groups  Json

  results    CompareResult[]
  newsGroups CompareGroupRecord[]

  @@index([savedAt(sort: Desc)])
}

/// グループ化されたニュースイベント（ベクトル検索用）
model CompareGroupRecord {
  id           String         @id @default(cuid())
  session      CompareSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sessionId    String

  groupTitle   String
  singleOutlet Boolean
  itemCount    Int
  /// 参加媒体名の配列を JSON で保存
  sources      Json

  savedAt      DateTime @default(now())

  // 埋め込みベクトル（グループタイトル + 記事タイトル群 + 媒体名）
  embedding    Unsupported("vector(1024)")?

  @@index([savedAt(sort: Desc)])
}

/// YouTube 動画の字幕分析結果
model YouTubeVideo {
  id             String   @id @default(cuid())
  videoId        String   @unique       // YouTube video ID (11文字)
  title          String
  channelName    String
  channelId      String                 // YouTube channel ID (UC...)
  description    String?
  thumbnailUrl   String?
  publishedAt    String?
  transcript     String                 // 分析に使用したテキスト（字幕 or description）
  transcriptType String   @default("transcript") // "transcript" | "description"
  analyzedAt     DateTime @default(now())

  economic       Float
  social         Float
  diplomatic     Float
  emotionalTone  Float
  biasWarning    Boolean
  confidence     Float
  summary        String
  counterOpinion String

  category       String?
  subcategory    String?

  embedding      Unsupported("vector(1024)")?

  @@index([channelId])
  @@index([analyzedAt(sort: Desc)])
}

/// 比較セッション内の各媒体分析結果
model CompareResult {
  id             String         @id @default(cuid())
  session        CompareSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sessionId      String

  title          String
  url            String?
  source         String?
  publishedAt    String?
  analyzedAt     DateTime       @default(now())

  economic       Float
  social         Float
  diplomatic     Float
  emotionalTone  Float
  biasWarning    Boolean
  confidence     Float
  summary        String
  counterOpinion String

  embedding      Unsupported("vector(1024)")?
}
