# ── Go API サーバー ───────────────────────────────────────
# Go API サーバーの URL（ブラウザから見えるアドレスを指定）
# Next.js API Route は削除済み — Go サーバーが必須
NEXT_PUBLIC_API_URL=http://localhost:8091

# ── Ollama ────────────────────────────────────────────────
# OllamaサーバーのベースURL
OLLAMA_BASE_URL=http://localhost:11434

# 3軸政治分析（economic/social/diplomatic）に使うモデル
OLLAMA_MODEL=gemma3:12b

# ニュースカテゴリ分類（8カテゴリ × 34サブカテゴリ）に使うモデル
CLASSIFY_MODEL=gemma3:4b

# テキスト埋め込みに使うモデル（出力次元: 768）
EMBED_MODEL=mxbai-embed-large

# マルチモデル分析モードで使うモデル一覧（カンマ区切り）
MULTI_MODELS=gemma3:12b,qwen3.5:4b,llama3.2

# ── 類似度閾値 ─────────────────────────────────────────────
# groupArticlesByEvent でのembeddingクラスタリング閾値（高いほど厳密）
GROUP_CLUSTER_THRESHOLD=0.72

# incrementalGroupArticles での既存グループへのマッチング閾値
FEED_GROUP_SIMILARITY_THRESHOLD=0.68

# embeddingカテゴリ分類でのconfidence閾値（これ未満はLLMにエスカレーション）
EMBED_CLASSIFY_THRESHOLD=0.5

# ── データベース ───────────────────────────────────────────
# PostgreSQL接続文字列（pgvectorエクステンション必須）
DATABASE_URL=postgresql://newsprism:newsprism@localhost:5432/newsprism

# ── 外部API ───────────────────────────────────────────────
# newsdata.io のAPIキー（未設定の場合はNewsdata取得をスキップ）
NEWSDATA_API_KEY=your_api_key_here
